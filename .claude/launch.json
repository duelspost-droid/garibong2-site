{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "http-server",
      "runtimeExecutable": "http-server",
      "runtimeArgs": [
        ".",
        "-p",
        "8000",
        "-c-1"
      ],
      "port": 8000
    },
    {
      "name": "python-http",
      "runtimeExecutable": "python",
      "runtimeArgs": [
        "-m",
        "http.server",
        "8001"
      ],
      "port": 8001
    },
    {
      "name": "node-http",
      "runtimeExecutable": "npx",
      "runtimeArgs": [
        "serve",
        "-l",
        "8002"
      ],
      "port": 8002
    }
  ]
}
